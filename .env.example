# Copy to `.env` and fill in. Never commit `.env`.
# Use KEY=value lines only — not Python dicts or JSON.

# --- Django (production / hosting) ---
# Local dev: set DJANGO_DEBUG=True so DEBUG is on and ALLOWED_HOSTS defaults to localhost.
# Production: DJANGO_DEBUG=False (or omit), set DJANGO_SECRET_KEY and DJANGO_ALLOWED_HOSTS.
DJANGO_DEBUG=True
# DJANGO_SECRET_KEY=long-random-string   # required when DEBUG is False
# DJANGO_ALLOWED_HOSTS=your-app.onrender.com,yourdomain.com

# Postgres: Neon / Render provide a connection string — use one of these approaches.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Or set PGDATABASE, PGUSER, PGPASSWORD, PGHOST (and optionally PGPORT).

# Recommended: single line from Cloudinary dashboard (API Keys → environment variable).
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or set these three (CLOUD_NAME must be the dashboard cloud name, e.g. dubggrxxu — not a key label):
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Sign-In — https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID (Web).
# Under "Authorized redirect URIs", add EVERY URL you will use (Google matches character-for-character):
#   http://127.0.0.1:8000/accounts/google/login/callback/
#   http://localhost:8000/accounts/google/login/callback/
# Use the same host in the browser as in this list (127.0.0.1 vs localhost must match).
# Production: https://YOUR_DOMAIN/accounts/google/login/callback/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Notifications: email, SMS, Web Push (each new Notification row can trigger these) ---
# Absolute site URL for links in email/push (no trailing slash), e.g. https://your-app.onrender.com
SITE_PUBLIC_URL=
NOTIFICATION_EMAIL=1
# SMS uses Twilio; only sent for order-related notifications when the order has a phone number.
NOTIFICATION_SMS=0
NOTIFICATION_WEB_PUSH=1
# Email (production: set host + credentials; dev uses console backend when DJANGO_DEBUG=True)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Web Push VAPID keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
# PEM private key; in .env use literal \n for newlines, or single-line PEM if your host allows
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=mailto:you@example.com
