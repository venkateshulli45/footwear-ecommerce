# Copy to `.env` and fill in. Never commit `.env`.
# Use KEY=value lines only — not Python dicts or JSON.

# From Cloudinary dashboard → Product environment credentials.
# CLOUDINARY_CLOUD_NAME must be the exact "Cloud name" (e.g. dxxxx or my-shop),
# not a display label like "Footwear". Leave all three empty to store uploads under media/ locally.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
